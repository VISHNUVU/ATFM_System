-- ================================================
-- STEP 1: CREATE airline_master TABLE
-- Purpose: Stores list of all airlines
-- PK: airline_code
-- ================================================
CREATE TABLE airline_master (
    airline_code VARCHAR(5) PRIMARY KEY,
    airline_name VARCHAR(100) NOT NULL
);

-- ================================================
-- STEP 2: CREATE airport_master TABLE
-- Purpose: Stores list of all airports
-- PK: airport_code
-- ================================================
CREATE TABLE airport_master (
    airport_code VARCHAR(5) PRIMARY KEY,
    airport_name VARCHAR(100) NOT NULL
);

-- ================================================
-- STEP 3: CREATE flight_plan TABLE
-- Purpose: Stores all planned flight details
-- PK: flight_plan_id
-- FK: airline_code → airline_master
-- FK: origin → airport_master
-- FK: destination → airport_master
-- FK: created_by → app_user
-- ================================================
CREATE TABLE flight_plan (
    flight_plan_id  SERIAL PRIMARY KEY,
    flight_no       VARCHAR(10),
    airline_code    VARCHAR(5) REFERENCES
                    airline_master(airline_code),
    origin          VARCHAR(5) REFERENCES
                    airport_master(airport_code),
    destination     VARCHAR(5) REFERENCES
                    airport_master(airport_code),
    sobt            TIMESTAMPTZ,
    created_by      INT REFERENCES
                    app_user(user_id)
);

-- ================================================
-- STEP 4: CREATE flight_operation TABLE
-- Purpose: Stores actual flight status and times
-- PK: op_id
-- FK: flight_plan_id → flight_plan
-- ================================================
CREATE TABLE flight_operation (
    op_id           SERIAL PRIMARY KEY,
    flight_plan_id  INT REFERENCES
                    flight_plan(flight_plan_id),
    aobt            TIMESTAMPTZ,
    atot            TIMESTAMPTZ,
    stand           VARCHAR(10),
    runway          VARCHAR(10),
    status          VARCHAR(20)
);

