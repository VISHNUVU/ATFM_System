-- ================================================
-- STEP 9: VERIFICATION JOIN QUERY
-- Connects all 4 tables together
-- Shows complete flight information
-- ================================================
-- Complete verification query
-- Shows both codes AND full names
SELECT
    fp.flight_plan_id,
    fp.flight_no,
    fp.airline_code,
    am.airline_name,
    fp.origin,
    ap1.airport_name AS origin_airport,
    fp.destination,
    ap2.airport_name AS destination_airport,
    fp.sobt,
    fo.aobt,
    fo.atot,
    fo.stand,
    fo.runway,
    fo.status
FROM flight_plan fp
JOIN flight_operation fo
    ON fp.flight_plan_id = fo.flight_plan_id
JOIN airline_master am
    ON fp.airline_code = am.airline_code
JOIN airport_master ap1
    ON fp.origin = ap1.airport_code
JOIN airport_master ap2
    ON fp.destination = ap2.airport_code
ORDER BY fp.flight_plan_id;
