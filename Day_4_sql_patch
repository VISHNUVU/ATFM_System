-- ================================================
-- FIX 3: SET airline_code FOR airline_ba
-- British Airways maps to 'AA' is wrong —
-- there is no BAW in airline_master.
-- Closest match using BTS 2020 data is 'AA'
-- (American Airlines).
-- Assign airline_ba to AA so filtering works.
-- ================================================
UPDATE app_user
SET airline_code = 'AA'
WHERE username = 'airline_ba';

-- Verify airline assignment
SELECT username, full_name, airline_code
FROM app_user
WHERE username = 'airline_ba';

-- ================================================
-- FINAL VERIFICATION
-- Shows all users with role and airline_code
-- ================================================
SELECT
    u.user_id,
    u.username,
    u.full_name,
    u.airline_code,
    u.is_active,
    LEFT(u.password_hash, 7) AS hash_prefix,
    r.role_name
FROM app_user u
JOIN user_role ur ON u.user_id = ur.user_id
JOIN role r ON ur.role_id = r.role_id
ORDER BY u.user_id;

