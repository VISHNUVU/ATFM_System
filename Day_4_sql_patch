-- ================================================
-- FIX 1: ADD airline_code TO app_user
-- The Flask app reads this column at login to
-- filter flight data for airline_operator role
-- ================================================
ALTER TABLE app_user
ADD COLUMN IF NOT EXISTS airline_code VARCHAR(5)
REFERENCES airline_master(airline_code);

-- Verify column added
SELECT column_name, data_type
FROM information_schema.columns
WHERE table_name = 'app_user'
AND column_name = 'airline_code';

